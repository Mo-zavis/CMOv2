{
  "mcpServers": {
    "figma": {
      "type": "http",
      "url": "https://mcp.figma.com/mcp"
    },
    "screenshot": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/codingthefuturewithai/screenshot_mcp_server.git",
        "screenshot_mcp_server-server"
      ]
    },
    "chrome-devtools": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"]
    },
    "twenty-crm": {
      "type": "stdio",
      "command": "node",
      "args": ["./mcp-servers/twenty/dist/index.js"],
      "env": {
        "TWENTY_API_KEY": "",
        "TWENTY_BASE_URL": ""
      }
    },
    "chatwoot": {
      "type": "stdio",
      "command": "node",
      "args": ["./mcp-servers/chatwoot/dist/index.js"],
      "env": {
        "CHATWOOT_BASE_URL": "",
        "CHATWOOT_API_ACCESS_TOKEN": "",
        "CHATWOOT_ACCOUNT_ID": ""
      }
    },
    "google-search-console": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "mcp-server-gsc"],
      "env": {
        "GOOGLE_APPLICATION_CREDENTIALS": ""
      }
    },
    "google-analytics": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "mcp-server-google-analytics"],
      "env": {
        "GOOGLE_CLIENT_EMAIL": "",
        "GOOGLE_PRIVATE_KEY": "",
        "GA_PROPERTY_ID": ""
      }
    },
    "meta-ads": {
      "type": "stdio",
      "command": "uvx",
      "args": ["meta-ads-mcp"],
      "env": {
        "META_ACCESS_TOKEN": "",
        "META_AD_ACCOUNT_ID": ""
      }
    }
  }
}
