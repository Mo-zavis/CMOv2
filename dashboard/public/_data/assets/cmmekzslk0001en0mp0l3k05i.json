{"id":"cmmekzslk0001en0mp0l3k05i","projectId":"cmmda4tdu00007oqcfk611gwg","campaignId":"cmmekujfn00012ihyp8y1mnei","type":"social_post","subtype":"feed_post","platform":"instagram","title":"Ramadan Health Tip: Hydration Between Iftar and Suhoor","description":null,"status":"IN_REVIEW","currentVersion":1,"metadata":"{\"model\":\"claude-opus-4-6\",\"post_type\":\"health_tip\",\"target_audience\":\"Healthcare providers and patients\",\"scheduled_time\":\"2026-03-11T18:00:00Z\",\"hashtags\":[\"RamadanHealthTip\",\"Hydration\",\"PatientWellness\",\"ZavisHealth\",\"RamadanCare\"],\"day\":5}","tags":null,"createdAt":"2026-03-06T07:36:50.313Z","updatedAt":"2026-03-06T07:46:29.247Z","versions":[{"id":"cmmekzslm0003en0m0etz8g5d","assetId":"cmmekzslk0001en0mp0l3k05i","version":1,"filePath":null,"content":"Your patients need this reminder.\n\nHydration window during Ramadan is limited. Here is how to make it count:\n\n- Drink water steadily between Iftar and Suhoor (not all at once)\n- Include water-rich foods: cucumber, watermelon, yogurt, soups\n- Avoid caffeine and high-sodium foods close to Suhoor\n- Set 2-3 hydration reminders during the evening\n\nHealthcare providers: share tips like these with your patients. It shows you care about their Ramadan experience, not just their medical records.\n\n#RamadanHealthTip #Hydration #PatientWellness #ZavisHealth #RamadanCare #HealthContent #PatientEngagement #PreventiveCare #HealthTech #WellnessTips","metadata":"{\"model\":\"claude-opus-4-6\",\"post_type\":\"health_tip\",\"target_audience\":\"Healthcare providers and patients\",\"scheduled_time\":\"2026-03-11T18:00:00Z\",\"hashtags\":[\"RamadanHealthTip\",\"Hydration\",\"PatientWellness\",\"ZavisHealth\",\"RamadanCare\"],\"day\":5}","changelog":"Initial generation","createdAt":"2026-03-06T07:36:50.314Z","feedbacks":[]}],"brandChecks":[{"id":"cmmelc7b00001r8sbmgxv4944","assetId":"cmmekzslk0001en0mp0l3k05i","versionNumber":1,"checkType":"visual_qa","score":90,"passed":true,"details":"