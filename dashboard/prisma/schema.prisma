generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// === CORE MODELS ===

model Project {
  id                    String                 @id @default(cuid())
  name                  String
  config                String?                // JSON string for brand settings
  assets                Asset[]
  campaigns             Campaign[]
  calendarEvents        CalendarEvent[]
  loopExecutions        LoopExecution[]
  metricSnapshots       MetricSnapshot[]
  researchArtifacts     ResearchArtifact[]
  optimizationDecisions OptimizationDecision[]
  researchBriefs        ResearchBrief[]
  standupSessions       StandupSession[]
  progressLogs          ProgressLog[]
  eventOpportunities    EventOpportunity[]
  createdAt             DateTime               @default(now())
}

model Asset {
  id             String           @id @default(cuid())
  projectId      String
  project        Project          @relation(fields: [projectId], references: [id])
  campaignId     String?
  campaign       Campaign?        @relation(fields: [campaignId], references: [id])
  type           String           // "image" | "copy" | "ad_creative" | "video" | "social_post" | "email"
  subtype        String?          // "blog_post" | "ad_copy" | "social_image" | "hero_banner" etc.
  platform       String?          // "linkedin" | "instagram" | "google_ads" | "meta_ads" etc.
  title          String
  description    String?
  status         String           @default("DRAFT")
  currentVersion Int              @default(1)
  metadata       String?          // JSON string
  tags           String?          // comma-separated
  versions       AssetVersion[]
  feedbacks      Feedback[]
  approvals      ApprovalAction[]
  brandChecks    BrandCheck[]
  scenes         VideoScene[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([projectId])
  @@index([campaignId])
  @@index([type])
  @@index([status])
}

model AssetVersion {
  id        String     @id @default(cuid())
  assetId   String
  asset     Asset      @relation(fields: [assetId], references: [id])
  version   Int
  filePath  String?    // path relative to /assets/
  content   String?    // for text-based assets (markdown, captions)
  metadata  String?    // JSON: generation params, model, prompt, etc.
  changelog String?    // what changed from previous version
  feedbacks Feedback[]
  createdAt DateTime   @default(now())

  @@unique([assetId, version])
  @@index([assetId])
}

model Feedback {
  id              String        @id @default(cuid())
  assetId         String
  asset           Asset         @relation(fields: [assetId], references: [id])
  versionId       String?
  version         AssetVersion? @relation(fields: [versionId], references: [id])
  author          String        @default("human")
  type            String        // "approval" | "revision" | "comment" | "qa_result"
  comment         String
  actionTaken     String?       // what the agent did in response
  resultVersionId String?       // version ID created as result of this feedback
  createdAt       DateTime      @default(now())

  @@index([assetId])
}

model ApprovalAction {
  id         String   @id @default(cuid())
  assetId    String
  asset      Asset    @relation(fields: [assetId], references: [id])
  fromStatus String
  toStatus   String
  actor      String   @default("human")
  reason     String?
  createdAt  DateTime @default(now())

  @@index([assetId])
}

model BrandCheck {
  id            String   @id @default(cuid())
  assetId       String
  asset         Asset    @relation(fields: [assetId], references: [id])
  versionNumber Int
  checkType     String   // "visual_qa" | "copy_compliance" | "brand_voice"
  score         Float?
  passed        Boolean
  details       String   // JSON: full QA report
  createdAt     DateTime @default(now())

  @@index([assetId])
}

model Campaign {
  id        String    @id @default(cuid())
  projectId String
  project   Project   @relation(fields: [projectId], references: [id])
  name      String
  objective String?
  status    String    @default("PLANNING")
  startDate DateTime?
  endDate   DateTime?
  budget    Float?
  pillar    String?   // "increase_revenue" | "reduce_no_shows" | "patient_satisfaction"
  metadata  String?   // JSON
  targeting String?   // JSON: demographics, age groups, job titles, industries, locations, audiences
  channels  String?   // JSON: array of channel configs (google_ads, meta_ads, linkedin, etc.)
  kpis      String?   // JSON: target metrics (demo_bookings, cac, roas, etc.)
  northStarTarget Float?    // target demo bookings for this campaign
  northStarActual Float?    // current actual demo bookings
  assets          Asset[]
  adGroups        AdGroup[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([projectId])
}

model AdGroup {
  id           String       @id @default(cuid())
  campaignId   String
  campaign     Campaign     @relation(fields: [campaignId], references: [id])
  name         String
  platform     String       // "google_ads" | "meta_ads" | "linkedin_ads"
  adType       String       // "search" | "display" | "video" | "feed" | "stories" | "reels"
  targeting    String?      // JSON: group-specific targeting overrides
  keywords     String?      // JSON: for Google Search (array of {keyword, matchType, bid})
  budget       Float?
  bidStrategy  String?      // "maximize_conversions" | "target_cpa" | "target_roas"
  status       String       @default("DRAFT")
  metadata     String?      // JSON: googleAds sync state, resource names, metrics
  creatives    AdCreative[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([campaignId])
}

model AdCreative {
  id           String   @id @default(cuid())
  adGroupId    String
  adGroup      AdGroup  @relation(fields: [adGroupId], references: [id])
  imageAssetId String?  // reference to image Asset
  copyAssetId  String?  // reference to copy Asset
  headline     String
  description  String?
  cta          String?  // "Book a Demo" | "Learn More" | "Get Started"
  landingUrl   String?
  format       String   // "single_image" | "carousel" | "responsive_search" | "video"
  utmParams    String?  // JSON: utm_source, utm_medium, utm_campaign, utm_content
  metadata     String?  // JSON: platform-specific settings
  status       String   @default("DRAFT")
  createdAt    DateTime @default(now())

  @@index([adGroupId])
}

model CalendarEvent {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id])
  title       String
  description String?
  date        DateTime
  endDate     DateTime?              // null = single-day; set = multi-day span
  eventType   String                 // campaign_launch | ad_start | social_post | content_publish | email_send | milestone
  platform    String?                // google_ads | meta_ads | linkedin | instagram | blog | null
  status      String    @default("PLANNED")
  assetId     String?
  campaignId  String?
  metadata    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([projectId])
  @@index([date])
  @@index([eventType])
}

model VideoScene {
  id              String   @id @default(cuid())
  assetId         String
  asset           Asset    @relation(fields: [assetId], references: [id])
  sceneNumber     Int
  title           String?
  description     String
  compositionType String   // "veo_only" | "veo_plus_remotion" | "remotion_only" | "still_image"
  startFramePath  String?
  endFramePath    String?
  clipPath        String?
  startTime       Float    @default(0)
  duration        Float    @default(5)
  voiceoverText   String?
  voiceoverPath   String?
  textOverlay     String?
  remotionConfig  String?  // JSON
  status          String   @default("PENDING")
  metadata        String?  // JSON
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([assetId, sceneNumber])
  @@index([assetId])
}

// === AGENTIC LOOP MODELS ===

model LoopExecution {
  id           String         @id @default(cuid())
  projectId    String
  project      Project        @relation(fields: [projectId], references: [id])
  campaignId   String?
  loopType     String         // "ads" | "content_seo" | "social" | "email" | "cross_channel"
  currentPhase String         // "research" | "planning" | "creation" | "deployment" | "monitoring" | "optimization"
  status       String         @default("ACTIVE") // ACTIVE | PAUSED | COMPLETED
  cycleNumber  Int            @default(1)
  config       String?        // JSON: loop-specific settings (check intervals, thresholds)
  summary      String?        // JSON: latest cycle summary
  parentLoopId String?        // for micro-cycles nested within a macro cycle
  parentPhase  String?        // which phase of the parent loop spawned this micro-cycle
  phases       LoopPhaseLog[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([projectId])
  @@index([campaignId])
  @@index([loopType])
  @@index([status])
  @@index([parentLoopId])
}

model LoopPhaseLog {
  id              String        @id @default(cuid())
  loopExecutionId String
  loopExecution   LoopExecution @relation(fields: [loopExecutionId], references: [id])
  phase           String        // research | planning | creation | deployment | monitoring | optimization
  cycleNumber     Int
  status          String        @default("IN_PROGRESS") // IN_PROGRESS | COMPLETED | FAILED | SKIPPED
  input           String?       // JSON: what data entered this phase
  output          String?       // JSON: what this phase produced
  decisions       String?       // JSON: key decisions made
  duration        Int?          // seconds
  createdAt       DateTime      @default(now())

  @@index([loopExecutionId])
}

model MetricSnapshot {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id])
  campaignId String?
  channel    String   // "google_ads" | "meta_ads" | "linkedin" | "organic_search" | "social" | "email" | "overall"
  metricType String   // "impressions" | "clicks" | "ctr" | "spend" | "conversions" | "cpa" | "roas" | "demo_bookings" | "website_visits" | "seo_rank"
  value      Float
  metadata   String?  // JSON: extra context
  period     String   // "daily" | "weekly" | "monthly"
  recordedAt DateTime @default(now())

  @@index([projectId])
  @@index([campaignId])
  @@index([channel])
  @@index([metricType])
  @@index([recordedAt])
}

model OptimizationDecision {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id])
  loopExecutionId String?
  campaignId      String?
  decisionType    String   // "budget_realloc" | "targeting_change" | "creative_swap" | "keyword_add" | "keyword_pause" | "bid_adjust" | "channel_pause" | "content_refresh"
  rationale       String   // human-readable explanation
  before          String   // JSON: state before change
  after           String   // JSON: state after change
  impact          String?  // JSON: measured impact after N days
  status          String   @default("PROPOSED") // PROPOSED | APPROVED | APPLIED | REJECTED | MEASURED
  createdAt       DateTime @default(now())

  @@index([projectId])
  @@index([campaignId])
  @@index([decisionType])
  @@index([status])
}

model ResearchArtifact {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id])
  campaignId   String?
  artifactType String   // "persona" | "keyword_list" | "competitor_analysis" | "audience_insight" | "ad_library_scan" | "content_gap"
  title        String
  data         String   // JSON: the research output
  source       String?  // where the data came from
  createdAt    DateTime @default(now())

  @@index([projectId])
  @@index([campaignId])
  @@index([artifactType])
}

// === RESEARCH & PLANNING LAYER ===

model ResearchBrief {
  id               String    @id @default(cuid())
  projectId        String
  project          Project   @relation(fields: [projectId], references: [id])
  campaignId       String?
  loopExecutionId  String?   // the loop this research is gating
  briefType        String    // "market" | "competitor" | "audience" | "channel" | "content" | "performance" | "brand" | "industry"
  question         String    // The research question to answer
  context          String?   // JSON: why this research is needed, what decision it informs
  status           String    @default("PENDING") // PENDING | IN_PROGRESS | COMPLETED | STALE
  findings         String?   // JSON: structured research findings
  confidence       Float?    // 0-1 confidence in findings
  sources          String?   // JSON: array of sources used
  expiresAt        DateTime? // when this research goes stale and needs refresh
  linkedDecisionId String?   // OptimizationDecision this research informs
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([projectId])
  @@index([campaignId])
  @@index([loopExecutionId])
  @@index([briefType])
  @@index([status])
}

// === STANDUP / ALIGNMENT SYSTEM ===

model StandupSession {
  id          String        @id @default(cuid())
  projectId   String
  project     Project       @relation(fields: [projectId], references: [id])
  sessionDate DateTime      @default(now())
  status      String        @default("PENDING") // PENDING | ACTIVE | AWAITING_RESPONSE | COMPLETED
  summary     String?       // AI-generated summary
  items       StandupItem[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([projectId])
  @@index([status])
  @@index([sessionDate])
}

model StandupItem {
  id         String         @id @default(cuid())
  standupId  String
  standup    StandupSession @relation(fields: [standupId], references: [id])
  category   String         // DONE | PLANNED | BLOCKED | PERMISSION | DEPENDENCY | INSIGHT | RESEARCH_NEEDED
  content    String         // What the item is about
  priority   String         @default("NORMAL") // LOW | NORMAL | HIGH | URGENT
  context    String?        // JSON: linked asset IDs, campaign IDs, loop IDs
  response   String?        // Human response to this item
  resolved   Boolean        @default(false)
  resolvedAt DateTime?
  createdAt  DateTime       @default(now())

  @@index([standupId])
  @@index([category])
}

// === PROGRESS TRACKING ===

model ProgressLog {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id])
  sessionDate   DateTime @default(now())
  sessionType   String   // "work" | "standup" | "research" | "optimization" | "review" | "planning"
  summary       String   // What happened in this session
  decisions     String?  // JSON: key decisions made and their rationale
  assetsCreated String?  // JSON: array of asset IDs created/modified
  loopsAdvanced String?  // JSON: array of loop IDs advanced
  blockers      String?  // JSON: current blockers with severity
  nextSteps     String?  // JSON: planned next actions with priority
  metadata      String?  // JSON: session duration, tools used, APIs called
  createdAt     DateTime @default(now())

  @@index([projectId])
  @@index([sessionDate])
  @@index([sessionType])
}

// === EVENT STRATEGY ===

model EventOpportunity {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id])
  name            String   // Event name
  eventType       String   // "conference" | "expo" | "meetup" | "webinar" | "workshop" | "awards" | "networking"
  location        String?  // City/venue
  region          String   @default("UAE") // "UAE" | "GCC" | "MENA" | "Global"
  startDate       DateTime?
  endDate         DateTime?
  website         String?  // Event URL
  relevanceScore  Float?   // 0-10, how relevant to Zavis target market
  audienceOverlap String?  // JSON: who attends (dental, medical, healthtech, investors)
  opportunities   String?  // JSON: speaking slots, sponsorship tiers, booth options, demo opportunities
  strategy        String?  // Our plan for this event (attend, speak, sponsor, exhibit)
  status          String   @default("IDENTIFIED") // IDENTIFIED | EVALUATING | COMMITTED | ATTENDED | SKIPPED
  outcome         String?  // JSON: post-event results (leads, contacts, content created)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([projectId])
  @@index([eventType])
  @@index([status])
  @@index([region])
}
